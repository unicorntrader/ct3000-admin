# ── Browser-bundle env vars (CRA inlines these at build time) ──────────────
# Anyone who can fetch the React bundle can read these. Never put secrets here.

REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sb_publishable_...
# Optional. Defaults to https://ct3000-react.vercel.app/signup?invite=
# REACT_APP_INVITE_BASE_URL=https://ct3000.app/signup?invite=

# ── Server-side env vars (only available to /api/* serverless routes) ──────
# Never prefix with REACT_APP_ — that would inline them into the browser.

# Bypasses RLS. Used by /api/* to read/write any user's data.
SUPABASE_SECRET_KEY=sb_secret_...

# Comma-separated allowlist. Real authorization gate for /api/*.
ADMIN_EMAILS=admin@example.com,other@example.com

# Optional. Defaults to https://ct3000-react.vercel.app/signup?invite=
# INVITE_BASE_URL=https://ct3000.app/signup?invite=

# ── Ghost (Philoinvestor) integration ──────────────────────────────────────

# Admin API key — id:secret pair from Ghost integrations.
GHOST_ADMIN_KEY=...:...

# Webhook signing secret — verifies incoming Ghost member events.
GHOST_WEBHOOK_SECRET=...
